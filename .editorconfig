root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,cshtml,razor}]
indent_style = space
indent_size = 4

[*.{js,ts,json,yml,yaml,md,sql}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sql]
indent_size = 2
